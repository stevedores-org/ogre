#!/bin/bash
# Pre-commit hook for OGRE
# Validates files before allowing commit
# Install: git config core.hooksPath .githooks

echo "🔍 OGRE Pre-Commit Validation"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Check for required documentation files
REQUIRED_FILES=("PLAN.md" "README.md" "TEAM_SUMMARY.md")
for file in "${REQUIRED_FILES[@]}"; do
    if ! test -f "$file"; then
        echo "❌ Missing required file: $file"
        exit 1
    fi
done
echo "✓ Required documentation files present"

# Check for common issues in staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(md|toml|json|yml|yaml)$' || true)

if [ -n "$STAGED_FILES" ]; then
    echo "Validating staged files..."

    # Check for trailing whitespace
    if git diff --cached | grep -q '^+.*[[:space:]]$'; then
        echo "⚠️  Trailing whitespace detected"
        echo "   Run: git diff --cached | grep '^+.*[[:space:]]$'"
        # Don't fail on whitespace - just warn
    fi

    echo "✓ File validation passed"
fi

# When Rust workspace is added (Phase 3+), run:
# if test -f Cargo.toml; then
#     echo "Running local-ci checks..."
#     if ! local-ci --profile pre-commit; then
#         echo "❌ Pre-commit checks failed"
#         exit 1
#     fi
# fi

echo ""
echo "✅ All pre-commit checks passed!"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
exit 0
